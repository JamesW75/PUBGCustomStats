@page "{statusCode:int}"
@model PUBGCustomStats.Web.Pages.StatusCodeModel
@{
    Layout = "_Layout";
    var code = Model.StatusCode;
}

<div class="container mt-5">
    <h1 class="display-4">@((code == 404) ? "Page not found" : $"Error {code}")</h1>
    @if (code == 404)
    {
        <p class="lead">The page you requested could not be found.</p>
    }
    else
    {
        <p class="lead">An error occurred (status code @code).</p>
    }

    <a asp-page="/Index" class="btn btn-primary">Return to home</a>
</div>
