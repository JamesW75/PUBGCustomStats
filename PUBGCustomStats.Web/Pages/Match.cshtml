    public string GetDamageDescription(dynamic evt)
    {
        var playerName = evt.PlayerIsNPC.GetValueOrDefault() ? evt.PlayerAccountId : evt.Player.PlayerName;
        var secondaryName = evt.SecondaryPlayerIsNPC.GetValueOrDefault() ? evt.SecondaryPlayerAccountId : evt.SecondaryPlayer.PlayerName;

        if (evt.SecondaryPlayerGuid.HasValue || evt.SecondaryPlayerIsNPC.GetValueOrDefault())
        {
            return $"{playerName} killed by {evt.DamageReason} from {secondaryName}";
        }
        else
        {
            return $"{playerName} died {evt.DamageReason}";
        }
    }

    public MarkupString FormatDescription(string description)
    {
        return (MarkupString)description.Replace("\r\n", "<br>")
                                        .Replace("\r", "<br>")
                                        .Replace("\n", "<br>");
    }

    public string GetRanking(int ranking)
    {
        switch (ranking % 10)
        {
            case 0:
            case 4:
            case 5:
            case 6:
            case 7:
            case 8:
            case 9:
                return ranking + "th";
            case 1:
                if (ranking % 100 == 11)
                {
                    return ranking + "th";
                }
                return ranking + "st";
            case 2:
                if (ranking % 100 == 12)
                {
                    return ranking + "th";
                }
                return ranking + "nd";
            case 3:
                if (ranking % 100 == 13)
                {
                    return ranking + "th";
                }
                return ranking + "rd";
        }
        return ranking.ToString();
    }

